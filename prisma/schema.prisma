// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  APPLICANT
  EMPLOYEE
  MANAGER
  MINISTER
  FINANCE
  ADMIN
}

enum PermitType {
  LANDING
  OVERFLIGHT
}

enum ApplicationStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  CORRECTION_REQUESTED
  MANAGER_REVIEW
  MINISTER_PENDING
  APPROVED
  REJECTED
  PERMIT_ISSUED
  INVOICE_REFERENCE_CREATED
}

enum DecisionType {
  APPROVE
  REJECT
  RETURN_FOR_CORRECTION
}

model User {
  id                  String               @id @default(cuid())
  fullName            String
  firstName           String?
  lastName            String?
  designation         String?
  phoneNumber         String?
  companyName         String?
  airlineType         String?
  countryOfOrigin     String?
  email               String               @unique
  passwordHash        String
  role                UserRole
  isActive            Boolean              @default(true)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  applications        Application[]        @relation("ApplicantApplications")
  workflowEvents      WorkflowEvent[]
  permits             Permit[]             @relation("PermitApprover")
  passwordResetTokens PasswordResetToken[]
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model SmtpSettings {
  id        String   @id @default("default")
  host      String
  port      Int
  secure    Boolean  @default(true)
  username  String?
  password  String?
  fromEmail String
  fromName  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Application {
  id                    String            @id @default(cuid())
  applicationRef        String            @unique
  applicantId           String
  permitType            PermitType
  status                ApplicationStatus @default(DRAFT)
  operatorName          String
  operatorEmail         String
  aircraftRegistration  String
  flightPurpose         String
  routeDetails          String
  arrivalOrOverflightAt DateTime
  departureAt           DateTime?
  submittedAt           DateTime?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  applicant             User              @relation("ApplicantApplications", fields: [applicantId], references: [id])
  attachments           Attachment[]
  workflowEvents        WorkflowEvent[]
  permit                Permit?
  chargeLines           ChargeLine[]
  invoiceReference      InvoiceReference?
}

model Attachment {
  id            String      @id @default(cuid())
  applicationId String
  fileName      String
  storageKey    String
  mimeType      String
  uploadedAt    DateTime    @default(now())
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
}

model WorkflowEvent {
  id            String             @id @default(cuid())
  applicationId String
  actorId       String
  fromStatus    ApplicationStatus?
  toStatus      ApplicationStatus
  decision      DecisionType?
  notes         String?
  createdAt     DateTime           @default(now())
  application   Application        @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  actor         User               @relation(fields: [actorId], references: [id])
}

model Permit {
  id                String      @id @default(cuid())
  applicationId     String      @unique
  permitNumber      String      @unique
  approvedById      String
  approvedAt        DateTime
  permitIssuedAt    DateTime
  permitDocumentKey String
  createdAt         DateTime    @default(now())
  application       Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  approvedBy        User        @relation("PermitApprover", fields: [approvedById], references: [id])
}

model ChargeLine {
  id            String      @id @default(cuid())
  applicationId String
  lineItem      String
  quantity      Decimal     @db.Decimal(10, 2)
  unitPrice     Decimal     @db.Decimal(10, 2)
  amount        Decimal     @db.Decimal(12, 2)
  createdAt     DateTime    @default(now())
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
}

model InvoiceReference {
  id                String      @id @default(cuid())
  applicationId     String      @unique
  referenceNumber   String      @unique
  totalAmount       Decimal     @db.Decimal(12, 2)
  generatedAt       DateTime    @default(now())
  generatedByName   String
  handedToFinance   Boolean     @default(false)
  handedToFinanceAt DateTime?
  application       Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
}
